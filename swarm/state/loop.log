/* Pick the nth TRUE entry in the given boolean array. */
staticfn xint16
pick_level(
    boolean *map, /* an array MAXLEVEL+1 in size */
    int nth)
{
    xint16 i;
    for (i = 1; i <= MAXLEVEL; i++)
        if (map[i] && !nth--)
            return i;
    panic("pick_level:  ran out of valid levels");
    /*NOTREACHED*/
    return 0;
}

